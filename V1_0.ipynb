        "<a href=\"https://colab.research.google.com/github/Sam53283/SCH-BOM-/blob/main/v1_0.ipynb\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
